# =============================================================================
# CEO-UFPE — Backend (projeto/backend)
# Exemplo de variáveis de ambiente (RNF06.3). Copie para `.env` e ajuste.
# NUNCA versione o `.env` real — apenas este `.env.example`.
# Config carregada via dotenv (ADR-0003). Credenciais nunca ficam hardcoded.
# =============================================================================

# --- Servidor HTTP ---------------------------------------------------------
# Porta do Express. server.ts lê process.env.PORT (default 3000).
PORT=3000

# --- PostgreSQL (ADR-0001 / ADR-0004) --------------------------------------
# O Postgres do CEO-UFPE sobe via docker compose publicado em 5433:5432.
# A 5432 do host já está ocupada por outro projeto (container duque-postgres),
# por isso usamos 5433 aqui — assim os dois coexistem sem conflito.
#
# Connection string usada pelo driver pg / Drizzle (ADR-0004):
DATABASE_URL=postgresql://ceo:ceo@localhost:5433/ceo_estoque

# Variáveis individuais (consumidas pelo compose.yaml ao subir o container).
# Mantenha em sincronia com a DATABASE_URL acima.
POSTGRES_USER=ceo
POSTGRES_PASSWORD=ceo
POSTGRES_DB=ceo_estoque
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Autenticação (EP01 / ADR-0005 — JWT) ----------------------------------
# Segredo de assinatura do JWT. Em produção, use um valor forte e secreto.
JWT_SECRET=troque-este-segredo-em-producao
# Tempo de expiração do token (formato aceito pelo jsonwebtoken, ex.: 8h, 30m).
JWT_EXPIRES_IN=8h

# --- Agente de Email da Dispensação (EP08 / ADR-0004) ----------------------
# Token de SERVIÇO compartilhado entre o worker do agente e o backend. O agente
# manda `Authorization: Bearer <AGENTE_TOKEN>` em POST /rascunhos (não é JWT —
# o agente é um worker, não um usuário logado). Se ausente, a rota responde 503
# (falha fechada). Em produção, use um valor forte e secreto, igual nos dois lados.
AGENTE_TOKEN=dev-token-trocar
